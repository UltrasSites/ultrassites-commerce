---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import ProductCard from '../../components/ProductCard.astro';
import CartDrawer from '../../components/CartDrawer.astro';
import { translations, languages } from '../../i18n/translations';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const langKey = lang && lang in translations ? lang : 'fr';
const t = (translations as Record<string, Record<string, string>>)[langKey] || {};

// Product data
const featuredProducts = [
  {
    slug: 'montre-carbon-x',
    name: 'Montre Carbon X',
    price: 289,
    badge: t.product_new,
    gradient: 'linear-gradient(135deg, #0a0a0a 0%, #1a1510 50%, #0a0a0a 100%)',
    image: 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=600&h=600&fit=crop&q=80',
  },
  {
    slug: 'sac-luxora-elite',
    name: 'Sac Luxora Elite',
    price: 189,
    badge: t.product_bestseller,
    gradient: 'linear-gradient(135deg, #100a08 0%, #1e1210 50%, #100a08 100%)',
    image: 'https://images.unsplash.com/photo-1548036328-c9fa89d128fa?w=600&h=600&fit=crop&q=80',
  },
  {
    slug: 'parfum-nuit-doree',
    name: 'Parfum Nuit Dorée',
    price: 129,
    originalPrice: 169,
    badge: t.product_sale,
    gradient: 'linear-gradient(135deg, #0d0a00 0%, #1a1500 50%, #0d0a00 100%)',
    image: 'https://images.unsplash.com/photo-1592945403244-b3fbafd7f539?w=600&h=600&fit=crop&q=80',
  },
  {
    slug: 'ceinture-signature',
    name: 'Ceinture Signature',
    price: 89,
    badge: t.product_new,
    gradient: 'linear-gradient(135deg, #080810 0%, #12121e 50%, #080810 100%)',
    image: 'https://images.unsplash.com/photo-1624222247344-550fb60583dc?w=600&h=600&fit=crop&q=80',
  },
];

const newArrivals = [
  {
    slug: 'bracelet-or-noir',
    name: 'Bracelet Or Noir',
    price: 159,
    badge: t.product_new,
    gradient: 'linear-gradient(135deg, #0a0a0a 0%, #1a1510 50%, #0a0a0a 100%)',
    image: 'https://images.unsplash.com/photo-1611591437281-460bfbe1220a?w=600&h=600&fit=crop&q=80',
  },
  {
    slug: 'lunettes-prestige',
    name: 'Lunettes Prestige',
    price: 219,
    badge: t.product_new,
    gradient: 'linear-gradient(135deg, #08080a 0%, #101018 50%, #08080a 100%)',
    image: 'https://images.unsplash.com/photo-1508296695146-257a814070b4?w=600&h=600&fit=crop&q=80',
  },
  {
    slug: 'foulard-soie-luxe',
    name: 'Foulard Soie Luxe',
    price: 99,
    originalPrice: 129,
    badge: t.product_sale,
    gradient: 'linear-gradient(135deg, #0a0508 0%, #180a10 50%, #0a0508 100%)',
    image: 'https://images.unsplash.com/photo-1601924994987-69e26d50dc26?w=600&h=600&fit=crop&q=80',
  },
  {
    slug: 'portefeuille-carbon',
    name: 'Portefeuille Carbon',
    price: 149,
    badge: t.product_bestseller,
    gradient: 'linear-gradient(135deg, #0a0a0a 0%, #1a1510 50%, #0a0a0a 100%)',
    image: 'https://images.unsplash.com/photo-1627123424574-724758594e93?w=600&h=600&fit=crop&q=80',
  },
];

const categories = [
  {
    id: 'watches',
    label: t.cat_watches,
    gradient: 'linear-gradient(135deg, #0a0a0a 0%, #1a1510 40%, #c9a84c1a 100%)',
    icon: '⌚',
    count: '24 articles',
  },
  {
    id: 'fashion',
    label: t.cat_fashion,
    gradient: 'linear-gradient(135deg, #0a0608 0%, #180810 40%, #c9a84c1a 100%)',
    icon: '👜',
    count: '38 articles',
  },
  {
    id: 'perfume',
    label: t.cat_perfume,
    gradient: 'linear-gradient(135deg, #080a08 0%, #101808 40%, #c9a84c1a 100%)',
    icon: '✨',
    count: '18 articles',
  },
];
---

<BaseLayout title={t.meta_title} description={t.meta_description} lang={langKey}>
  <Header lang={langKey} />
  <CartDrawer lang={langKey} />

  <main id="main-content">

    <!-- ═══════════════════════════════════════
         HERO SECTION
    ═══════════════════════════════════════ -->
    <section id="hero">
      <!-- Veo product video background -->
      <div class="hero-video-wrap" aria-hidden="true">
        <video
          class="hero-video"
          autoplay
          muted
          loop
          playsinline
          preload="none"
          poster=""
        >
          <source src="/videos/watch.webm" type="video/webm" />
          <source src="/videos/watch.mp4" type="video/mp4" />
        </video>
        <div class="hero-video-overlay"></div>
      </div>

      <!-- Animated background (orbs on top of video) -->
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
        <div class="hero-orb hero-orb-3"></div>
        <div class="hero-grid"></div>
      </div>

      <div class="hero-content fade-up">
        <!-- Label -->
        <div class="eyebrow hero-eyebrow">{t.hero_label}</div>

        <!-- Main title -->
        <h1 class="hero-title">
          {t.hero_title.split('\n').map((line: string, i: number) => (
            <span class={`hero-line ${i === 1 ? 'gold-shimmer' : ''}`}>{line}</span>
          ))}
        </h1>

        <!-- Subtitle -->
        <p class="hero-sub">{t.hero_subtitle}</p>

        <!-- CTAs -->
        <div class="hero-actions">
          <a href={`/${langKey}/#featured`} class="liquid-btn primary hero-cta pulse-cta" id="hero-main-cta">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin-right:8px;flex-shrink:0">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
            </svg>
            {t.hero_cta}
          </a>
          <a href={`/${langKey}/#new-arrivals`} class="liquid-btn ghost">
            {t.hero_cta2}
          </a>
        </div>

        <!-- Trust badges -->
        <div class="hero-trust">
          <div class="trust-item">
            <span class="trust-icon">🚚</span>
            <span>Livraison 48h</span>
          </div>
          <div class="trust-sep"></div>
          <div class="trust-item">
            <span class="trust-icon">🛡️</span>
            <span>Retours 30 jours</span>
          </div>
          <div class="trust-sep"></div>
          <div class="trust-item">
            <span class="trust-icon">⭐</span>
            <span>4.9/5 · 1 240 avis</span>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="hero-scroll" aria-hidden="true">
        <div class="scroll-line"></div>
        <span>Scroll</span>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         FEATURED PRODUCTS
    ═══════════════════════════════════════ -->
    <section id="featured" class="section-pad">
      <div class="container">
        <div class="section-header centered fade-up">
          <div class="eyebrow">{t.featured_title}</div>
          <h2 class="section-title">{t.featured_title}</h2>
          <p class="section-subtitle">{t.featured_subtitle}</p>
        </div>

        <div class="products-grid">
          {featuredProducts.map((product, i) => (
            <div style={`transition-delay: ${i * 0.1}s`}>
              <ProductCard
                name={product.name}
                price={product.price}
                originalPrice={product.originalPrice}
                badge={product.badge}
                image={product.image}
                gradient={product.gradient}
                slug={product.slug}
                lang={langKey}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         CATEGORIES BANNER
    ═══════════════════════════════════════ -->
    <section id="categories" class="section-pad categories-section">
      <div class="container">
        <div class="section-header centered fade-up">
          <div class="eyebrow">{t.categories_title}</div>
          <h2 class="section-title">{t.categories_title}</h2>
        </div>

        <div class="categories-grid">
          {categories.map((cat, i) => (
            <a
              href={`/${langKey}/#${cat.id}`}
              class="cat-card liquid-glass fade-up"
              style={`transition-delay: ${i * 0.12}s; background: ${cat.gradient};`}
            >
              <div class="cat-icon">{cat.icon}</div>
              <div class="cat-info">
                <h3 class="cat-name">{cat.label}</h3>
                <span class="cat-count">{cat.count}</span>
              </div>
              <div class="cat-arrow">
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
                </svg>
              </div>
              <div class="cat-shine" aria-hidden="true"></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         NEW ARRIVALS
    ═══════════════════════════════════════ -->
    <section id="new-arrivals" class="section-pad new-arrivals-section">
      <div class="container">
        <div class="section-header fade-up">
          <div class="eyebrow">{t.new_arrivals_title}</div>
          <h2 class="section-title">{t.new_arrivals_title}</h2>
        </div>
      </div>

      <!-- Horizontal scroll on mobile -->
      <div class="scroll-track-wrap">
        <div class="scroll-track">
          {newArrivals.map((product, i) => (
            <div class="scroll-track-item" style={`transition-delay: ${i * 0.1}s`}>
              <ProductCard
                name={product.name}
                price={product.price}
                originalPrice={product.originalPrice}
                badge={product.badge}
                image={product.image}
                gradient={product.gradient}
                slug={product.slug}
                lang={langKey}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         ABOUT / BRAND STORY
    ═══════════════════════════════════════ -->
    <section id="about" class="section-pad about-section">
      <div class="container">
        <div class="about-grid fade-up">
          <div class="about-left">
            <div class="eyebrow">Notre Histoire</div>
            <h2 class="section-title about-title">
              L'Art du<br/>
              <em class="about-em">Luxe Accessible</em>
            </h2>
            <p class="about-text">
              LUXORA naît de la conviction que l'excellence ne devrait pas être réservée à quelques-uns. Chaque pièce de notre collection est sélectionnée avec la même exigence qu'une maison de haute couture — mais à un prix qui respecte votre intelligence.
            </p>
            <p class="about-text">
              De la montre au parfum, chaque détail est pensé pour vous faire vivre une expérience premium, du premier regard jusqu'à l'utilisation quotidienne.
            </p>
            <div class="about-stats">
              <div class="about-stat">
                <span class="stat-num">1 240<span class="stat-plus">+</span></span>
                <span class="stat-label">Clients satisfaits</span>
              </div>
              <div class="about-stat">
                <span class="stat-num">80<span class="stat-plus">+</span></span>
                <span class="stat-label">Produits exclusifs</span>
              </div>
              <div class="about-stat">
                <span class="stat-num">4.9<span class="stat-plus">★</span></span>
                <span class="stat-label">Note moyenne</span>
              </div>
            </div>
          </div>
          <div class="about-right">
            <div class="about-image-grid">
              <div class="about-img-card about-img-large liquid-glass">
                <img
                  src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=600&h=800&fit=crop&q=80"
                  alt="LUXORA boutique"
                  width="600" height="800"
                  loading="lazy"
                />
              </div>
              <div class="about-img-small-col">
                <div class="about-img-card liquid-glass">
                  <img
                    src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?w=400&h=400&fit=crop&q=80"
                    alt="Collection mode"
                    width="400" height="400"
                    loading="lazy"
                  />
                </div>
                <div class="about-img-card liquid-glass">
                  <img
                    src="https://images.unsplash.com/photo-1560769629-975ec94e6a86?w=400&h=400&fit=crop&q=80"
                    alt="Accessoires"
                    width="400" height="400"
                    loading="lazy"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         NEWSLETTER
    ═══════════════════════════════════════ -->
    <section id="newsletter" class="section-pad newsletter-section">
      <div class="container">
        <div class="newsletter-card liquid-glass fade-up">
          <div class="newsletter-glow" aria-hidden="true"></div>
          <div class="newsletter-content">
            <div class="eyebrow">{t.newsletter_title}</div>
            <h2 class="newsletter-title">{t.newsletter_title}</h2>
            <p class="newsletter-sub">{t.newsletter_subtitle}</p>
            <form class="newsletter-form" onsubmit="handleNewsletter(event)">
              <div class="newsletter-input-wrap">
                <input
                  type="email"
                  class="newsletter-input"
                  placeholder={t.newsletter_placeholder}
                  required
                  autocomplete="email"
                />
                <button type="submit" class="liquid-btn primary newsletter-cta">
                  {t.newsletter_cta}
                </button>
              </div>
              <p class="newsletter-note">
                En vous inscrivant, vous acceptez de recevoir nos newsletters. Désabonnement possible à tout moment.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         FOOTER
    ═══════════════════════════════════════ -->
    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">
          <!-- Brand -->
          <div class="footer-brand">
            <a href={`/${langKey}/`} class="footer-logo">LUXORA<span class="footer-logo-dot">●</span></a>
            <p class="footer-tagline">L'excellence à portée de main.</p>
            <p class="footer-created">
              {t.footer_by} <a href="https://ultras-sites.com" class="footer-agency" target="_blank" rel="noopener">Ultras-Sites</a>
            </p>
          </div>

          <!-- Links -->
          <div class="footer-links-col">
            <h3 class="footer-col-title">Boutique</h3>
            <a href={`/${langKey}/`} class="footer-link">{t.footer_shop}</a>
            <a href={`/${langKey}/#featured`} class="footer-link">{t.featured_title}</a>
            <a href={`/${langKey}/#new-arrivals`} class="footer-link">{t.new_arrivals_title}</a>
          </div>

          <div class="footer-links-col">
            <h3 class="footer-col-title">Informations</h3>
            <a href="#" class="footer-link">{t.footer_about}</a>
            <a href="#" class="footer-link">{t.footer_contact}</a>
            <a href="#" class="footer-link">{t.footer_legal}</a>
            <a href="#" class="footer-link">{t.footer_privacy}</a>
          </div>

          <!-- Languages -->
          <div class="footer-links-col">
            <h3 class="footer-col-title">Langues</h3>
            {Object.entries(languages).map(([key, label]) => (
              <a
                href={`/${key}/`}
                class={`footer-link ${key === langKey ? 'footer-link-active' : ''}`}
              >
                {label}
              </a>
            ))}
          </div>
        </div>

        <div class="footer-bottom">
          <p class="footer-rights">{t.footer_rights}</p>
          <div class="footer-badges">
            <span class="footer-badge">SSL Sécurisé</span>
            <span class="footer-badge">RGPD Compliant</span>
            <span class="footer-badge">Demo Officielle · Ultras-Sites</span>
          </div>
        </div>
      </div>
    </footer>

  </main>

  <!-- Mobile sticky CTA bar -->
  <div class="mobile-sticky-cta" id="mobile-sticky-cta">
    <a href={`/${langKey}/#featured`} class="liquid-btn primary mobile-sticky-btn pulse-cta">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="margin-right:8px;flex-shrink:0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
      </svg>
      {t.hero_cta}
    </a>
  </div>
</BaseLayout>

<style>
  /* ══════════ HERO ══════════ */
  #hero {
    min-height: 100svh;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 9rem 4.5rem 4rem;
    text-align: center;
  }

  /* Veo video background */
  .hero-video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.2s ease;
  }

  .hero-video.loaded { opacity: 1; }

  .hero-video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(var(--bg, 18,7,58), 0.75) 0%,
      rgba(var(--bg, 18,7,58), 0.55) 50%,
      rgba(var(--bg, 18,7,58), 0.85) 100%
    );
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.7) 0%,
      rgba(0,0,0,0.45) 50%,
      rgba(0,0,0,0.75) 100%
    );
  }

  /* Animated background (orbs) */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .hero-orb-1 {
    width: 600px;
    height: 600px;
    top: -200px;
    left: -100px;
    background: radial-gradient(circle, rgba(201,168,76,0.12) 0%, transparent 70%);
    animation: orbFloat1 15s ease-in-out infinite;
  }

  .hero-orb-2 {
    width: 500px;
    height: 500px;
    top: 50%;
    right: -150px;
    background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
    animation: orbFloat2 18s ease-in-out infinite;
  }

  .hero-orb-3 {
    width: 400px;
    height: 400px;
    bottom: -100px;
    left: 30%;
    background: radial-gradient(circle, rgba(100, 60, 150, 0.06) 0%, transparent 70%);
    animation: orbFloat3 12s ease-in-out infinite;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(201,168,76,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,168,76,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 80%);
  }

  @keyframes orbFloat1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(60px, -40px) scale(1.1); }
    66% { transform: translate(-40px, 60px) scale(0.95); }
  }

  @keyframes orbFloat2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-80px, -60px) scale(1.15); }
  }

  @keyframes orbFloat3 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(40px, -30px); }
  }

  /* Hero content */
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-eyebrow {
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 10vw, 11rem);
    line-height: 0.85;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--text);
    margin-bottom: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.05em;
  }

  .hero-line {
    display: block;
  }

  .hero-sub {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--text2);
    font-weight: 300;
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 3.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: 4rem;
  }

  .hero-cta { padding: 1.2rem 3rem; font-size: 0.65rem; }

  /* Pulse/glow CTA animation */
  @keyframes pulseCTA {
    0%, 100% {
      box-shadow:
        inset 0 1px 1px rgba(255,255,255,0.3),
        0 10px 30px rgba(var(--accent-rgb), 0.3),
        0 0 0 0 rgba(var(--accent-rgb), 0.4);
    }
    50% {
      box-shadow:
        inset 0 1px 1px rgba(255,255,255,0.3),
        0 16px 48px rgba(var(--accent-rgb), 0.55),
        0 0 0 8px rgba(var(--accent-rgb), 0);
    }
  }

  .pulse-cta {
    animation: pulseCTA 2.5s ease-in-out infinite;
  }

  .pulse-cta:hover {
    animation: none;
  }

  /* Trust badges */
  .hero-trust {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    color: var(--text2);
    font-weight: 500;
    letter-spacing: 0.05em;
  }

  .trust-icon { font-size: 1rem; }

  .trust-sep {
    width: 1px;
    height: 20px;
    background: var(--glass-border);
  }

  /* Scroll indicator */
  .hero-scroll {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.55rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
