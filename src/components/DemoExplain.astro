---
// DemoExplain — bandeau "Démo Ultras-Sites" vendeur
// Props: features array (3-4 items), waUrl, ctaLabel
interface Props {
  features?: { icon: string; title: string; text: string }[];
  waUrl?: string;
  badge?: string;
  title?: string;
  subtitle?: string;
  cta?: string;
  note?: string;
}
const {
  features = [
    { icon: '📅', title: 'Prise de RDV en ligne', text: 'Vos clients réservent leurs créneaux 24/7, sans appel téléphonique.' },
    { icon: '⚡', title: 'Affichage instantané mobile', text: 'Lighthouse 95-100/100 mesuré. Vos visiteurs ne quittent pas avant le chargement.' },
    { icon: '🌍', title: 'Multilingue automatique', text: 'FR / EN / ES / PT en 1 clic, sans plugin payant.' },
    { icon: '🔒', title: 'Vos coordonnées masquées', text: 'Boutons "Appeler" et "Email" cliquables sans exposer email/téléphone aux bots.' },
  ],
  waUrl = 'https://wa.me/351920782244?text=Je%20veux%20cette%20démo%20pour%20mon%20cabinet',
  badge = 'Démo Ultras-Sites',
  title = 'Voici ce que peut faire votre site',
  subtitle = 'Cette démo est 100% fonctionnelle. Votre version personnalisée est livrée en moins de 7 jours.',
  cta = 'Recevoir cette démo pour mon business',
  note = '800€ tout compris · maquette gratuite en 24h',
} = Astro.props;
---

<section class="demo-explain-section">
  <div class="demo-explain-wrap">
    <div class="demo-explain-head">
      <span class="demo-explain-badge">💡 {badge}</span>
      <h2 class="demo-explain-title">{title}</h2>
      <p class="demo-explain-sub">{subtitle}</p>
    </div>

    <div class="demo-explain-grid">
      {features.map(f => (
        <div class="demo-explain-card">
          <span class="demo-explain-icon" aria-hidden="true">{f.icon}</span>
          <h3 class="demo-explain-card-title">{f.title}</h3>
          <p class="demo-explain-card-text">{f.text}</p>
        </div>
      ))}
    </div>

    <div class="demo-explain-cta">
      <a href={waUrl} target="_blank" rel="noopener" class="demo-explain-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        {cta}
      </a>
      <p class="demo-explain-note">{note}</p>
    </div>
  </div>
</section>

<style>
  .demo-explain-section {
    padding: 4rem 1.25rem;
    background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-secondary, var(--color-bg)) 100%);
    border-top: 1px solid var(--color-border, rgba(255,255,255,0.06));
    border-bottom: 1px solid var(--color-border, rgba(255,255,255,0.06));
    position: relative;
    overflow: hidden;
  }
  .demo-explain-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 0%, var(--color-accent, #D4B2A7) 0%, transparent 70%);
    opacity: 0.06;
    pointer-events: none;
  }
  .demo-explain-wrap {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .demo-explain-head {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .demo-explain-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-accent, #D4B2A7);
    background: color-mix(in srgb, var(--color-accent, #D4B2A7) 10%, transparent);
    color: var(--color-accent, #D4B2A7);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .demo-explain-title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--color-text, #fff);
    margin: 0.5rem 0;
    font-family: var(--font-serif, 'Playfair Display', serif);
    font-style: italic;
  }
  .demo-explain-sub {
    color: var(--color-text-muted, rgba(255,255,255,0.65));
    font-size: 0.95rem;
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.55;
  }
  .demo-explain-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .demo-explain-card {
    padding: 1.25rem;
    border-radius: 16px;
    background: color-mix(in srgb, var(--color-text, #fff) 4%, transparent);
    border: 1px solid var(--color-border, rgba(255,255,255,0.08));
    backdrop-filter: blur(8px);
    transition: transform .25s ease, border-color .25s ease;
  }
  .demo-explain-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-accent, #D4B2A7);
  }
  .demo-explain-icon {
    font-size: 1.5rem;
    display: block;
    margin-bottom: 0.5rem;
  }
  .demo-explain-card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text, #fff);
    margin: 0 0 0.35rem 0;
  }
  .demo-explain-card-text {
    font-size: 0.82rem;
    color: var(--color-text-muted, rgba(255,255,255,0.6));
    line-height: 1.55;
    margin: 0;
  }
  .demo-explain-cta {
    text-align: center;
  }
  .demo-explain-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1.6rem;
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
    color: #fff;
    text-decoration: none;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    box-shadow: 0 8px 24px rgba(37,211,102,0.3);
    transition: transform .2s ease, box-shadow .2s ease;
  }
  .demo-explain-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(37,211,102,0.4);
  }
  .demo-explain-note {
    margin-top: 0.75rem;
    font-size: 0.78rem;
    color: var(--color-text-muted, rgba(255,255,255,0.5));
    font-style: italic;
  }
  @media (max-width: 640px) {
    .demo-explain-section { padding: 3rem 1rem; }
    .demo-explain-grid { grid-template-columns: 1fr; }
  }
</style>
