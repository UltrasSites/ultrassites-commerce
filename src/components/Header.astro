---
import { translations, languages } from '../i18n/translations';

interface Props {
  lang: string;
  cartCount?: number;
}

const { lang, cartCount = 0 } = Astro.props;
const langKey = lang && lang in translations ? lang : 'fr';
const t = (translations as Record<string, Record<string, string>>)[langKey] || {};

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const pathWithoutLang = pathSegments.slice(1).join('/') || '';
---

<!-- ═══════════ DESKTOP HEADER ═══════════ -->
<header id="main-header" class="liquid-glass">
  <a href={`/${langKey}/`} class="logo-link">
    <span class="logo-text">LUXORA</span>
    <span class="logo-dot">●</span>
  </a>

  <nav class="desktop-nav">
    <a href={`/${langKey}/`}>{t.nav_shop}</a>
    <a href={`/${langKey}/#new-arrivals`}>{t.nav_new}</a>
    <a href={`/${langKey}/#about`}>{t.nav_about}</a>
  </nav>

  <div class="header-right">
    <!-- Language Switcher Desktop -->
    <div class="lang-wrap" id="lang-wrap-desktop">
      <button
        type="button"
        id="lang-btn-desktop"
        class="lang-btn"
        aria-label={t.lang_btn_aria}
        aria-expanded="false"
        aria-haspopup="true"
      >
        <span class="lang-code">{langKey.toUpperCase()}</span>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
          <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
      <div
        id="lang-dropdown-desktop"
        class="lang-dropdown hidden"
        role="menu"
      >
        {Object.entries(languages).map(([key, label]) => (
          <a
            href={pathWithoutLang ? `/${key}/${pathWithoutLang}` : `/${key}/`}
            class={`lang-option ${key === langKey ? 'active' : ''}`}
            role="menuitem"
          >
            {label}
          </a>
        ))}
      </div>
    </div>

    <!-- Cart -->
    <button
      type="button"
      id="cart-btn-desktop"
      class="cart-btn"
      aria-label={t.nav_cart}
      data-cart
    >
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0z"/>
      </svg>
      <span id="cart-count" style={`display: ${cartCount > 0 ? 'flex' : 'none'}`}>{cartCount}</span>
    </button>
  </div>
</header>

<!-- ═══════════ MOBILE DOCK ═══════════ -->
<div class="lg-dock liquid-glass" id="mobile-dock">
  <!-- Accueil -->
  <a href={`/${langKey}/`} class="dock-btn d-home" aria-label="Accueil">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
    </svg>
  </a>

  <div class="lg-sep"></div>

  <!-- Catalogue -->
  <a href={`/${langKey}/#catalogue`} class="dock-btn d-catalogue" aria-label="Catalogue">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6zm0 9.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25zm9.75-9.75A2.25 2.25 0 0 1 15.75 3.75H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6zm0 9.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25z"/>
    </svg>
  </a>

  <div class="lg-sep"></div>

  <!-- Cart avec badge -->
  <button type="button" class="dock-btn d-cart" id="cart-btn-mobile" data-cart aria-label={t.nav_cart}>
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0z"/>
    </svg>
    <span id="cart-count" style={`display: ${cartCount > 0 ? 'flex' : 'none'}`}>{cartCount}</span>
  </button>

  <div class="lg-sep"></div>

  <!-- Compte -->
  <button type="button" class="dock-btn d-account" id="dock-menu-btn" aria-label="Menu compte">
    <svg id="dock-burger" style="width:22px;height:22px;transition:opacity 0.3s" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0zM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
    </svg>
    <svg id="dock-close" style="width:22px;height:22px;position:absolute;inset:0;margin:auto;opacity:0;pointer-events:none;transform:rotate(90deg);transition:opacity 0.3s,transform 0.3s" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
</div>

<!-- ═══════════ MOBILE MENU PANEL ═══════════ -->
<div class="menu-overlay" id="menu-overlay"></div>
<div class="menu-panel liquid-glass" id="menu-panel">
  <div class="mp-header">
    <span class="mp-logo">LUXORA</span>
    <button type="button" class="mp-close" id="menu-close-btn" aria-label={t.menu_close}>
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <nav class="mp-nav">
    <a href={`/${langKey}/`} class="mp-link menu-link">{t.nav_shop}</a>
    <a href={`/${langKey}/#new-arrivals`} class="mp-link menu-link">{t.nav_new}</a>
    <a href={`/${langKey}/#about`} class="mp-link menu-link">{t.nav_about}</a>
    <a href={`/${langKey}/#newsletter`} class="mp-link menu-link">{t.nav_contact}</a>
  </nav>
  <div class="mp-footer">
    <a href={`/${langKey}/`} class="liquid-btn primary" style="width:100%;justify-content:center">
      {t.hero_cta}
    </a>
  </div>
</div>

<style>
  /* ══════════ DESKTOP HEADER ══════════ */
  header {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 400;
    width: 90%;
    max-width: 1200px;
    height: 60px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 1023px) {
    header {
      display: none;
    }
  }

  /* Logo */
  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
  }

  .logo-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.15em;
    color: var(--text);
    line-height: 1;
  }

  .logo-dot {
    color: var(--accent);
    font-size: 0.5rem;
    margin-bottom: 2px;
  }

  /* Desktop nav */
  .desktop-nav {
    display: flex;
    gap: 3rem;
  }

  .desktop-nav a {
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--text2);
    transition: color 0.3s;
  }

  .desktop-nav a:hover {
    color: var(--accent);
  }

  /* Header right */
  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Language btn desktop */
  .lang-wrap {
    position: relative;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 99px;
    color: var(--text2);
    padding: 0.5rem 1rem;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    transition: all 0.3s;
  }

  .lang-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 140px;
    background: var(--bg2);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 16px 40px rgba(0,0,0,0.5);
    z-index: 500;
  }

  .lang-dropdown.hidden { display: none; }

  .lang-option {
    display: block;
    padding: 0.7rem 1.2rem;
    font-size: 0.75rem;
    color: var(--text2);
    font-family: 'Outfit', sans-serif;
    transition: all 0.2s;
  }

  .lang-option:hover,
  .lang-option.active {
    background: rgba(var(--accent-rgb), 0.1);
    color: var(--accent);
  }

  /* Cart btn */
  .cart-btn {
    position: relative;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--text2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s;
  }

  .cart-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  #cart-count {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 18px;
    height: 18px;
    background: var(--accent);
    color: #000;
    border-radius: 50%;
    font-size: 0.6rem;
    font-weight: 700;
    align-items: center;
    justify-content: center;
    font-family: 'Outfit', sans-serif;
  }

  /* ══════════ MOBILE DOCK ══════════ */
  .lg-dock {
    display: none;
    position: fixed;
    bottom: calc(1.6rem + env(safe-area-inset-bottom));
    left: 50%;
    transform: translateX(-50%);
    z-index: 600;
    padding: 12px 16px;
    border-radius: 99px;
    gap: 10px;
    align-items: center;
  }

  @media (max-width: 1023px) {
    .lg-dock { display: flex; }
  }

  .dock-btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    cursor: pointer;
    border: none;
    overflow: hidden;
    transition: transform 0.3s;
  }

  .dock-btn:active { transform: scale(0.85); }

  .dock-btn svg {
    width: 22px;
    height: 22px;
    position: relative;
    z-index: 2;
  }

  .d-home {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--text2);
    text-decoration: none;
  }

  .d-home:hover { color: var(--accent); }

  .d-catalogue {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--text2);
    text-decoration: none;
  }

  .d-catalogue:hover { color: var(--accent); }

  .d-cart {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
    color: #000;
    box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.4);
  }

  .d-account {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--text);
  }

  .d-menu {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: blur(10px);
    color: var(--text);
  }

  .d-lang {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: blur(10px);
    color: var(--text2);
    font-family: 'Outfit', sans-serif;
  }

  .lg-sep {
    width: 1px;
    height: 28px;
    background: var(--glass-border);
  }

  /* Mobile lang dropdown */
  .dock-lang-wrap { position: relative; }

  .lang-dropdown-mobile {
    position: absolute;
    bottom: calc(100% + 12px);
    right: 0;
    min-width: 140px;
    background: var(--bg2);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 -16px 40px rgba(0,0,0,0.5);
    z-index: 700;
  }

  .lang-dropdown-mobile.hidden { display: none; }

  .lang-option-mobile {
    display: block;
    padding: 0.8rem 1.2rem;
    font-size: 0.8rem;
    color: var(--text2);
    font-family: 'Outfit', sans-serif;
    transition: all 0.2s;
  }

  .lang-option-mobile:hover,
  .lang-option-mobile.active {
    background: rgba(var(--accent-rgb), 0.1);
    color: var(--accent);
  }

  /* ══════════ MENU OVERLAY & PANEL ══════════ */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 700;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(12px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s;
  }

  .menu-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  .menu-panel {
    position: fixed;
    bottom: calc(110px + env(safe-area-inset-bottom));
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    z-index: 800;
    width: min(92vw, 400px);
    border-radius: 28px;
    padding: 2rem;
    opacity: 0;
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .menu-panel.open {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  .mp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--glass-border);
  }

  .mp-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 0.15em;
    color: var(--accent);
  }

  .mp-close {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--text2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s;
  }

  .mp-close:hover { border-color: var(--accent); color: var(--accent); }

  .mp-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 2rem;
  }

  .mp-link {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 600;
    color: var(--text);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--glass-border);
    transition: color 0.3s, padding-left 0.3s;
  }

  .mp-link:hover {
    color: var(--accent);
    padding-left: 0.5rem;
  }

  .mp-footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>

<script is:inline>
  (function() {
    // Desktop lang dropdown
    var langBtnD = document.getElementById('lang-btn-desktop');
    var langDropD = document.getElementById('lang-dropdown-desktop');

    if (langBtnD && langDropD) {
      langBtnD.addEventListener('click', function(e) {
        e.stopPropagation();
        var hidden = langDropD.classList.contains('hidden');
        langDropD.classList.toggle('hidden', !hidden);
        langBtnD.setAttribute('aria-expanded', String(hidden));
      });
      document.addEventListener('click', function() {
        langDropD.classList.add('hidden');
        langBtnD.setAttribute('aria-expanded', 'false');
      });
    }

    // Mobile lang dropdown
    var langBtnM = document.getElementById('lang-btn-mobile');
    var langDropM = document.getElementById('lang-dropdown-mobile');

    if (langBtnM && langDropM) {
      langBtnM.addEventListener('click', function(e) {
        e.stopPropagation();
        var hidden = langDropM.classList.contains('hidden');
        langDropM.classList.toggle('hidden', !hidden);
        langBtnM.setAttribute('aria-expanded', String(hidden));
      });
      document.addEventListener('click', function() {
        langDropM.classList.add('hidden');
      });
    }

    // Mobile menu
    var overlay = document.getElementById('menu-overlay');
    var panel = document.getElementById('menu-panel');
    var dockMenuBtn = document.getElementById('dock-menu-btn');
    var menuCloseBtn = document.getElementById('menu-close-btn');
    var burger = document.getElementById('dock-burger');
    var closeIcon = document.getElementById('dock-close');
    var menuOpen = false;

    function openMenu() {
      if (overlay) overlay.classList.add('open');
      if (panel) panel.classList.add('open');
      document.body.style.overflow = 'hidden';
      menuOpen = true;
      if (burger) burger.style.opacity = '0';
      if (closeIcon) { closeIcon.style.opacity = '1'; closeIcon.style.pointerEvents = 'auto'; closeIcon.style.transform = 'rotate(0deg)'; }
    }

    function closeMenu() {
      if (overlay) overlay.classList.remove('open');
      if (panel) panel.classList.remove('open');
      document.body.style.overflow = '';
      menuOpen = false;
      if (burger) burger.style.opacity = '1';
      if (closeIcon) { closeIcon.style.opacity = '0'; closeIcon.style.pointerEvents = 'none'; closeIcon.style.transform = 'rotate(90deg)'; }
    }

    if (dockMenuBtn) dockMenuBtn.addEventListener('click', function() { menuOpen ? closeMenu() : openMenu(); });
    if (menuCloseBtn) menuCloseBtn.addEventListener('click', closeMenu);
    if (overlay) overlay.addEventListener('click', closeMenu);

    document.querySelectorAll('.menu-link').forEach(function(el) {
      el.addEventListener('click', closeMenu);
    });

    // Swipe-down to close menu panel
    var touchStartY = 0;
    var touchStartX = 0;
    if (panel) {
      panel.addEventListener('touchstart', function(e) {
        touchStartY = e.touches[0].clientY;
        touchStartX = e.touches[0].clientX;
      }, { passive: true });
      panel.addEventListener('touchend', function(e) {
        var dy = e.changedTouches[0].clientY - touchStartY;
        var dx = Math.abs(e.changedTouches[0].clientX - touchStartX);
        if (dy > 60 && dx < 60) closeMenu();
      }, { passive: true });
    }

    // Cart drawer open
    document.querySelectorAll('[data-cart]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var drawer = document.getElementById('cart-drawer');
        var drawerOverlay = document.getElementById('cart-overlay');
        if (drawer) drawer.classList.add('open');
        if (drawerOverlay) drawerOverlay.classList.add('open');
        document.body.style.overflow = 'hidden';
        if (typeof updateCartDrawer === 'function') updateCartDrawer();
      });
    });
  })();
</script>
