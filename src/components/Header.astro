---
import { translations, languages } from '../i18n/translations';

interface Props {
  lang: string;
  cartCount?: number;
}

const { lang, cartCount = 0 } = Astro.props;
const langKey = lang && lang in translations ? lang : 'fr';
const t = (translations as Record<string, Record<string, string>>)[langKey] || {};

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const pathWithoutLang = pathSegments.slice(1).join('/') || '';
---

<!-- ═══════════ DESKTOP HEADER ═══════════ -->
<header id="main-header" class="liquid-glass">
  <a href={`/${langKey}/`} class="logo-link">
    <span class="logo-text">LUXORA</span>
    <span class="logo-dot">●</span>
  </a>

  <nav class="desktop-nav">
    <a href={`/${langKey}/`}>{t.nav_shop}</a>
    <a href={`/${langKey}/#new-arrivals`}>{t.nav_new}</a>
    <a href={`/${langKey}/#about`}>{t.nav_about}</a>
  </nav>

  <div class="header-right">
    <!-- Desktop Theme Switcher -->
    <div class="desktop-theme-wrap" id="desktop-theme-wrap">
      <button type="button" id="desktop-theme-btn" class="desktop-theme-btn" aria-label="Changer de thème">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 0 20V2z" fill="currentColor" stroke="none" opacity="0.4"/>
        </svg>
      </button>
      <div id="desktop-theme-picker" class="desktop-theme-picker hidden" role="menu">
        <button class="theme-swatch" data-theme-name="violet" aria-label="Violet">
          <span class="swatch-dot" style="background:linear-gradient(135deg,#12073a,#e8b84b)"></span>
          <span class="swatch-label">VIOLET</span>
        </button>
        <button class="theme-swatch" data-theme-name="midnight" aria-label="Midnight">
          <span class="swatch-dot" style="background:linear-gradient(135deg,#040d1a,#7eb8f7)"></span>
          <span class="swatch-label">MIDNIGHT</span>
        </button>
        <button class="theme-swatch" data-theme-name="ember" aria-label="Ember">
          <span class="swatch-dot" style="background:linear-gradient(135deg,#1a0a05,#e8784b)"></span>
          <span class="swatch-label">EMBER</span>
        </button>
        <button class="theme-swatch" data-theme-name="rose" aria-label="Rose">
          <span class="swatch-dot" style="background:linear-gradient(135deg,#1a0812,#e8a4c0)"></span>
          <span class="swatch-label">ROSE</span>
        </button>
      </div>
    </div>

    <!-- Language Switcher Desktop -->
    <div class="lang-wrap" id="lang-wrap-desktop">
      <button
        type="button"
        id="lang-btn-desktop"
        class="lang-btn"
        aria-label={t.lang_btn_aria}
        aria-expanded="false"
        aria-haspopup="true"
      >
        <span class="lang-code">{langKey.toUpperCase()}</span>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
          <path d="M2 4l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
      <div
        id="lang-dropdown-desktop"
        class="lang-dropdown hidden"
        role="menu"
      >
        {Object.entries(languages).map(([key, label]) => (
          <a
            href={pathWithoutLang ? `/${key}/${pathWithoutLang}` : `/${key}/`}
            class={`lang-option ${key === langKey ? 'active' : ''}`}
            role="menuitem"
          >
            {label}
          </a>
        ))}
      </div>
    </div>

    <!-- Cart -->
    <button
      type="button"
      id="cart-btn-desktop"
      class="cart-btn"
      aria-label={t.nav_cart}
      data-cart
    >
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0z"/>
      </svg>
      <span id="cart-count" style={`display: ${cartCount > 0 ? 'flex' : 'none'}`}>{cartCount}</span>
    </button>
  </div>
</header>

<!-- ═══════════ MOBILE DOCK ═══════════ -->
<div class="lg-dock liquid-glass" id="mobile-dock">
  <!-- Accueil -->
  <a href={`/${langKey}/`} class="dock-btn d-home" aria-label="Accueil">
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
    </svg>
  </a>

  <div class="lg-sep"></div>

  <!-- Langue -->
  <div class="dock-lang-wrap" id="dock-lang-wrap">
    <button type="button" class="dock-btn d-lang" id="lang-dock-btn" aria-label={t.lang_btn_aria}>
      <span style="font-size:0.7rem;font-weight:700;font-family:'Outfit',sans-serif">{langKey.toUpperCase()}</span>
    </button>
    <div id="lang-picker-mobile" class="theme-picker hidden" role="menu" style="bottom: calc(100% + 12px); right: -60px;">
      {Object.entries(languages).map(([key, label]) => (
        <a
          href={pathWithoutLang ? `/${key}/${pathWithoutLang}` : `/${key}/`}
          class={`theme-swatch ${key === langKey ? 'active' : ''}`}
          style="text-decoration:none"
        >
          <span class="swatch-label" style="font-size:0.7rem">{label.toUpperCase()}</span>
        </a>
      ))}
    </div>
  </div>

  <div class="lg-sep"></div>

  <!-- Cart avec badge -->
  <button type="button" class="dock-btn d-cart" id="cart-btn-mobile" data-cart aria-label={t.nav_cart}>
    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0z"/>
    </svg>
    <span id="cart-count" style={`display: ${cartCount > 0 ? 'flex' : 'none'}`}>{cartCount}</span>
  </button>

  <div class="lg-sep"></div>

  <!-- Compte -->
  <button type="button" class="dock-btn d-account" id="dock-menu-btn" aria-label="Menu compte">
    <svg id="dock-burger" style="width:22px;height:22px;transition:opacity 0.3s" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0zM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>
    </svg>
    <svg id="dock-close" style="width:22px;height:22px;position:absolute;inset:0;margin:auto;opacity:0;pointer-events:none;transform:rotate(90deg);transition:opacity 0.3s,transform 0.3s" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>

  <div class="lg-sep"></div>

  <!-- Theme Picker -->
  <div class="dock-theme-wrap" id="dock-theme-wrap">
    <button type="button" class="dock-btn d-theme" id="theme-dock-btn" aria-label="Changer de thème">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/><path d="M12 2a10 10 0 0 1 0 20V2z" fill="currentColor" stroke="none" opacity="0.3"/><circle cx="12" cy="12" r="3" fill="currentColor"/>
      </svg>
    </button>
    <div id="theme-picker" class="theme-picker hidden" role="menu">
      <button class="theme-swatch" data-theme-name="violet" aria-label="Violet">
        <span class="swatch-dot" style="background:linear-gradient(135deg,#12073a,#e8b84b)"></span>
        <span class="swatch-label">VIOLET</span>
      </button>
      <button class="theme-swatch" data-theme-name="midnight" aria-label="Midnight">
        <span class="swatch-dot" style="background:linear-gradient(135deg,#040d1a,#7eb8f7)"></span>
        <span class="swatch-label">MIDNIGHT</span>
      </button>
      <button class="theme-swatch" data-theme-name="ember" aria-label="Ember">
        <span class="swatch-dot" style="background:linear-gradient(135deg,#1a0a05,#e8784b)"></span>
        <span class="swatch-label">EMBER</span>
      </button>
      <button class="theme-swatch" data-theme-name="rose" aria-label="Rose Gold">
        <span class="swatch-dot" style="background:linear-gradient(135deg,#1a0812,#e8a4c0)"></span>
        <span class="swatch-label">ROSE</span>
      </button>
    </div>
  </div>
</div>

<!-- ═══════════ MOBILE MENU PANEL ═══════════ -->
<div class="menu-overlay" id="menu-overlay"></div>
<div class="menu-panel liquid-glass" id="menu-panel">
  <div class="mp-header">
    <span class="mp-logo">LUXORA</span>
    <button type="button" class="mp-close" id="menu-close-btn" aria-label={t.menu_close}>
      <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <nav class="mp-nav">
    <a href={`/${langKey}/`} class="mp-link menu-link">{t.nav_shop}</a>
    <a href={`/${langKey}/#new-arrivals`} class="mp-link menu-link">{t.nav_new}</a>
    <a href={`/${langKey}/#about`} class="mp-link menu-link">{t.nav_about}</a>
    <a href={`/${langKey}/#newsletter`} class="mp-link menu-link">{t.nav_contact}</a>
  </nav>

  <!-- Language grid in menu panel -->
  <div class="mp-lang-section">
    <div class="mp-section-label">Langue</div>
    <div class="mp-lang-grid">
      {Object.entries(languages).map(([key, label]) => (
        <a
          href={pathWithoutLang ? `/${key}/${pathWithoutLang}` : `/${key}/`}
          class={`mp-lang-item ${key === langKey ? 'active' : ''}`}
        >
          <span class="mp-lang-code">{key.toUpperCase()}</span>
          <span class="mp-lang-label">{label}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Theme switcher in menu panel -->
  <div class="mp-theme-section">
    <div class="mp-section-label">Thème</div>
    <div class="mp-theme-dots">
      <button class="mp-theme-dot" data-theme-name="violet" aria-label="Violet" style="background:linear-gradient(135deg,#12073a,#e8b84b)"></button>
      <button class="mp-theme-dot" data-theme-name="midnight" aria-label="Midnight" style="background:linear-gradient(135deg,#040d1a,#7eb8f7)"></button>
      <button class="mp-theme-dot" data-theme-name="ember" aria-label="Ember" style="background:linear-gradient(135deg,#1a0a05,#e8784b)"></button>
      <button class="mp-theme-dot" data-theme-name="rose" aria-label="Rose" style="background:linear-gradient(135deg,#1a0812,#e8a4c0)"></button>
    </div>
  </div>

  <div class="mp-footer">
    <a href={`/${langKey}/#featured`} class="liquid-btn primary menu-link" style="width:100%;justify-content:center">
      {t.hero_cta}
    </a>
  </div>
</div>

<style>
  /* ══════════ DESKTOP HEADER ══════════ */
  header {
    position: fixed;
    top: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 400;
    width: 90%;
    max-width: 1200px;
    height: 60px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 1023px) {
    header {
      display: none;
    }
  }

  /* Logo */
  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
  }

  .logo-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.15em;
    color: var(--text);
    line-height: 1;
  }

  .logo-dot {
    color: var(--accent);
    font-size: 0.5rem;
    margin-bottom: 2px;
  }

  /* Desktop nav */
  .desktop-nav {
    display: flex;
    gap: 3rem;
  }

  .desktop-nav a {
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--text2);
    transition: color 0.3s;
  }

  .desktop-nav a:hover {
    color: var(--accent);
  }

  /* Header right */
  .header-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Language btn desktop */
  .lang-wrap {
    position: relative;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 99px;
    color: var(--text2);
    padding: 0.5rem 1rem;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    cursor: pointer;
    font-family: 'Outfit', sans-serif;
    transition: all 0.3s;
  }

  .lang-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .lang-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 140px;
    background: var(--bg2);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 16px 40px rgba(0,0,0,0.5);
    z-index: 500;
  }

  .lang-dropdown.hidden { display: none; }

  .lang-option {
    display: block;
    padding: 0.7rem 1.2rem;
    font-size: 0.75rem;
    color: var(--text2);
    font-family: 'Outfit', sans-serif;
    transition: all 0.2s;
  }

  .lang-option:hover,
  .lang-option.active {
    background: rgba(var(--accent-rgb), 0.1);
    color: var(--accent);
  }

  /* Cart btn */
  .cart-btn {
    position: relative;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--text2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s;
  }

  .cart-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  #cart-count {
    position: absolute;
    top: -4px;
    right: -4px;
    width: 18px;
    height: 18px;
    background: var(--accent);
    color: #000;
    border-radius: 50%;
    font-size: 0.6rem;
    font-weight: 700;
    align-items: center;
    justify-content: center;
    font-family: 'Outfit', sans-serif;
  }

  /* ══════════ MOBILE DOCK ══════════ */
  .lg-dock {
    display: none;
    position: fixed;
    bottom: calc(1.6rem + env(safe-area-inset-bottom));
    left: 50%;
    transform: translateX(-50%);
    z-index: 600;
    padding: 12px 16px;
    border-radius: 99px;
    gap: 10px;
    align-items: center;
  }

  @media (max-width: 1023px) {
    .lg-dock { display: flex; }
  }

  .dock-btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    cursor: pointer;
    border: none;
    overflow: hidden;
    transition: transform 0.3s;
  }

  .dock-btn:active { transform: scale(0.85); }

  .dock-btn svg {
    width: 22px;
    height: 22px;
    position: relative;
    z-index: 2;
  }

  .d-home {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--text2);
    text-decoration: none;
  }

  .d-home:hover { color: var(--accent); }

  .d-catalogue {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--text2);
    text-decoration: none;
  }

  .d-catalogue:hover { color: var(--accent); }

  .d-cart {
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
    color: #000;
    box-shadow: 0 4px 16px rgba(var(--accent-rgb), 0.4);
  }

  .d-account {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--text);
  }

  .d-menu {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: blur(10px);
    color: var(--text);
  }

  .d-lang {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: blur(10px);
    color: var(--text2);
    font-family: 'Outfit', sans-serif;
  }

  .lg-sep {
    width: 1px;
    height: 28px;
    background: var(--glass-border);
  }

  /* Dock theme picker */
  .dock-theme-wrap { position: relative; }

  .d-theme {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border) !important;
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    color: var(--accent);
  }

  .theme-picker {
    position: absolute;
    bottom: calc(100% + 12px);
    right: -20px;
    background: var(--bg2);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    box-shadow: 0 -16px 40px rgba(0,0,0,0.6);
    z-index: 700;
    min-width: 150px;
  }

  .theme-picker.hidden { display: none; }

  .theme-swatch {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.7rem;
    border-radius: 12px;
    border: 1px solid transparent;
    background: transparent;
    cursor: pointer;
    transition: all 0.25s;
    width: 100%;
    text-align: left;
  }

  .theme-swatch:hover, .theme-swatch.active {
    background: rgba(255,255,255,0.06);
    border-color: var(--accent);
  }

  .swatch-dot {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 1px solid rgba(255,255,255,0.15);
  }

  .swatch-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--text2);
  }

  /* Mobile lang dropdown */
  .dock-lang-wrap { position: relative; }

  .lang-dropdown-mobile {
    position: absolute;
    bottom: calc(100% + 12px);
    right: 0;
    min-width: 140px;
    background: var(--bg2);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 -16px 40px rgba(0,0,0,0.5);
    z-index: 700;
  }

  .lang-dropdown-mobile.hidden { display: none; }

  .lang-option-mobile {
    display: block;
    padding: 0.8rem 1.2rem;
    font-size: 0.8rem;
    color: var(--text2);
    font-family: 'Outfit', sans-serif;
    transition: all 0.2s;
  }

  .lang-option-mobile:hover,
  .lang-option-mobile.active {
    background: rgba(var(--accent-rgb), 0.1);
    color: var(--accent);
  }

  /* ══════════ MENU OVERLAY & PANEL ══════════ */
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 700;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .menu-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  .menu-panel {
    position: fixed;
    bottom: calc(110px + env(safe-area-inset-bottom));
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    z-index: 800;
    width: min(92vw, 400px);
    border-radius: 28px;
    padding: 2rem;
    opacity: 0;
    pointer-events: none;
    transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .menu-panel.open {
    opacity: 1;
    pointer-events: all;
    transform: translateX(-50%) translateY(0);
  }

  .mp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--glass-border);
  }

  .mp-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 0.15em;
    color: var(--accent);
  }

  .mp-close {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--text2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s;
  }

  .mp-close:hover { border-color: var(--accent); color: var(--accent); }

  .mp-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 2rem;
  }

  .mp-link {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-size: 2rem;
    font-weight: 600;
    color: var(--text);
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--glass-border);
    transition: color 0.3s, padding-left 0.3s;
  }

  .mp-link:hover {
    color: var(--accent);
    padding-left: 0.5rem;
  }

  .mp-footer {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Menu panel — language grid */
  .mp-lang-section,
  .mp-theme-section {
    margin-bottom: 1.25rem;
  }

  .mp-section-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 0.75rem;
  }

  .mp-lang-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .mp-lang-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.8rem;
    border-radius: 12px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    transition: all 0.25s;
    text-decoration: none;
  }

  .mp-lang-item:hover,
  .mp-lang-item.active {
    border-color: var(--accent);
    background: rgba(var(--accent-rgb), 0.1);
  }

  .mp-lang-code {
    font-family: 'Outfit', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--accent);
  }

  .mp-lang-label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.7rem;
    color: var(--text2);
  }

  .mp-theme-dots {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .mp-theme-dot {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    transition: all 0.25s;
    flex-shrink: 0;
  }

  .mp-theme-dot:hover,
  .mp-theme-dot.active {
    border-color: var(--text);
    transform: scale(1.15);
  }

  /* Desktop theme button */
  .desktop-theme-wrap {
    position: relative;
  }

  .desktop-theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    color: var(--accent);
    cursor: pointer;
    transition: all 0.3s;
  }

  .desktop-theme-btn:hover {
    border-color: var(--accent);
    transform: scale(1.05);
  }

  .desktop-theme-picker {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 150px;
    background: var(--bg2);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    box-shadow: 0 16px 40px rgba(0,0,0,0.6);
    z-index: 600;
  }

  .desktop-theme-picker.hidden { display: none; }
</style>

<script is:inline>
  (function() {
    // Desktop lang dropdown
    var langBtnD = document.getElementById('lang-btn-desktop');
    var langDropD = document.getElementById('lang-dropdown-desktop');

    if (langBtnD && langDropD) {
      langBtnD.addEventListener('click', function(e) {
        e.stopPropagation();
        var hidden = langDropD.classList.contains('hidden');
        langDropD.classList.toggle('hidden', !hidden);
        langBtnD.setAttribute('aria-expanded', String(hidden));
      });
      document.addEventListener('click', function() {
        langDropD.classList.add('hidden');
        langBtnD.setAttribute('aria-expanded', 'false');
      });
    }

    // Mobile lang dropdown
    var langBtnM = document.getElementById('lang-btn-mobile');
    var langDropM = document.getElementById('lang-dropdown-mobile');

    if (langBtnM && langDropM) {
      langBtnM.addEventListener('click', function(e) {
        e.stopPropagation();
        var hidden = langDropM.classList.contains('hidden');
        langDropM.classList.toggle('hidden', !hidden);
        langBtnM.setAttribute('aria-expanded', String(hidden));
      });
      document.addEventListener('click', function() {
        langDropM.classList.add('hidden');
      });
    }

    // Mobile menu
    var overlay = document.getElementById('menu-overlay');
    var panel = document.getElementById('menu-panel');
    var dockMenuBtn = document.getElementById('dock-menu-btn');
    var menuCloseBtn = document.getElementById('menu-close-btn');
    var burger = document.getElementById('dock-burger');
    var closeIcon = document.getElementById('dock-close');
    var menuOpen = false;

    function openMenu() {
      if (overlay) overlay.classList.add('open');
      if (panel) panel.classList.add('open');
      document.body.style.overflow = 'hidden';
      menuOpen = true;
      if (burger) burger.style.opacity = '0';
      if (closeIcon) { closeIcon.style.opacity = '1'; closeIcon.style.pointerEvents = 'auto'; closeIcon.style.transform = 'rotate(0deg)'; }
    }

    function closeMenu() {
      if (overlay) overlay.classList.remove('open');
      if (panel) panel.classList.remove('open');
      document.body.style.overflow = '';
      menuOpen = false;
      if (burger) burger.style.opacity = '1';
      if (closeIcon) { closeIcon.style.opacity = '0'; closeIcon.style.pointerEvents = 'none'; closeIcon.style.transform = 'rotate(90deg)'; }
    }

    if (dockMenuBtn) dockMenuBtn.addEventListener('click', function() { menuOpen ? closeMenu() : openMenu(); });
    if (menuCloseBtn) menuCloseBtn.addEventListener('click', closeMenu);
    if (overlay) overlay.addEventListener('click', closeMenu);

    document.querySelectorAll('.menu-link').forEach(function(el) {
      el.addEventListener('click', closeMenu);
    });

    // Swipe-down to close menu panel — real-time with velocity
    var mStartY = 0;
    var mCurrentY = 0;
    var mIsSwiping = false;
    var mStartTime = 0;

    if (panel) {
      panel.addEventListener('touchstart', function(e) {
        if (e.touches.length > 1) return;
        mStartY = e.touches[0].clientY;
        mStartTime = Date.now();
        mIsSwiping = false;
        panel.style.transition = 'none';
      }, { passive: true });

      panel.addEventListener('touchmove', function(e) {
        if (e.touches.length > 1) return;
        mCurrentY = e.touches[0].clientY;
        var dy = mCurrentY - mStartY;
        var dx = Math.abs(e.touches[0].clientX - e.touches[0].clientX); // Placeholder for X delta if needed

        if (!mIsSwiping && dy > 10) {
          mIsSwiping = true;
        }

        if (mIsSwiping && dy > 0) {
          panel.style.transform = 'translateX(-50%) translateY(' + dy + 'px)';
          var progress = Math.min(dy / 150, 1);
          if (overlay) overlay.style.opacity = String(1 - progress);
        }
      }, { passive: true });

      panel.addEventListener('touchend', function(e) {
        if (!mIsSwiping) {
          panel.style.transition = '';
          return;
        }
        var dy = mCurrentY - mStartY;
        var duration = Date.now() - mStartTime;
        var velocity = dy / duration;

        panel.style.transition = '';
        if (dy > 120 || (velocity > 0.4 && dy > 40)) {
          if (navigator.vibrate) navigator.vibrate(10);
          closeMenu();
        } else {
          panel.style.transform = 'translateX(-50%) translateY(0)';
          if (overlay) overlay.style.opacity = '';
        }
        mIsSwiping = false;
      }, { passive: true });

      panel.addEventListener('touchcancel', function() {
        panel.style.transition = '';
        panel.style.transform = 'translateX(-50%) translateY(0)';
        if (overlay) overlay.style.opacity = '';
        mIsSwiping = false;
      }, { passive: true });
    }

    // Cart drawer open
    document.querySelectorAll('[data-cart]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var drawer = document.getElementById('cart-drawer');
        var drawerOverlay = document.getElementById('cart-overlay');
        if (drawer) drawer.classList.add('open');
        if (drawerOverlay) drawerOverlay.classList.add('open');
        document.body.style.overflow = 'hidden';
        if (typeof updateCartDrawer === 'function') updateCartDrawer();
      });
    });

    // Theme Picker
    var themes = {
      violet:   { bg: '#12073a', bg2: '#1c0e52', bg3: '#261566', accent: '#e8b84b', accentRgb: '232,184,75', accentDark: '#b88c28', text: '#f0ecff', text2: '#a89dd4', text3: '#7a6fa8', glassBg: 'rgba(18,7,58,0.6)' },
      midnight: { bg: '#040d1a', bg2: '#081828', bg3: '#0d2438', accent: '#7eb8f7', accentRgb: '126,184,247', accentDark: '#4a8fc7', text: '#e8f0fc', text2: '#7098c8', text3: '#4a6888', glassBg: 'rgba(4,13,26,0.62)' },
      ember:    { bg: '#1a0a05', bg2: '#261208', bg3: '#32180b', accent: '#e8784b', accentRgb: '232,120,75', accentDark: '#b84f28', text: '#fdf0eb', text2: '#c89078', text3: '#986050', glassBg: 'rgba(26,10,5,0.62)' },
      rose:     { bg: '#1a0812', bg2: '#26101c', bg3: '#331828', accent: '#e8a4c0', accentRgb: '232,164,192', accentDark: '#b87098', text: '#fdedf4', text2: '#c888a8', text3: '#986078', glassBg: 'rgba(26,8,18,0.62)' }
    };

    var themeDockBtn = document.getElementById('theme-dock-btn');
    var themePicker = document.getElementById('theme-picker');
    var desktopThemeBtn = document.getElementById('desktop-theme-btn');
    var desktopThemePicker = document.getElementById('desktop-theme-picker');
    var themeSwatches = document.querySelectorAll('.theme-swatch');
    var mpThemeDots = document.querySelectorAll('.mp-theme-dot');

    function applyTheme(name) {
      var t = themes[name];
      if (!t) return;
      var r = document.documentElement.style;
      r.setProperty('--bg', t.bg);
      r.setProperty('--bg2', t.bg2);
      r.setProperty('--bg3', t.bg3);
      r.setProperty('--accent', t.accent);
      r.setProperty('--accent-rgb', t.accentRgb);
      r.setProperty('--accent-dark', t.accentDark);
      r.setProperty('--text', t.text);
      r.setProperty('--text2', t.text2);
      r.setProperty('--text3', t.text3);
      r.setProperty('--glass-bg', t.glassBg);
      localStorage.setItem('veloro-theme', name);
      localStorage.setItem('theme-luxora', name);
      themeSwatches.forEach(function(s) {
        s.classList.toggle('active', s.getAttribute('data-theme-name') === name);
      });
      mpThemeDots.forEach(function(s) {
        s.classList.toggle('active', s.getAttribute('data-theme-name') === name);
      });
    }

    // Dock theme picker
    if (themeDockBtn && themePicker) {
      themeDockBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        themePicker.classList.toggle('hidden');
        if (desktopThemePicker) desktopThemePicker.classList.add('hidden');
        if (langPickerM) langPickerM.classList.add('hidden');
      });
      document.addEventListener('click', function() { themePicker.classList.add('hidden'); });
      themePicker.addEventListener('click', function(e) { e.stopPropagation(); });
    }

    // Dock lang picker
    var langDockBtn = document.getElementById('lang-dock-btn');
    var langPickerM = document.getElementById('lang-picker-mobile');
    if (langDockBtn && langPickerM) {
      langDockBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        langPickerM.classList.toggle('hidden');
        if (themePicker) themePicker.classList.add('hidden');
      });
      document.addEventListener('click', function() { langPickerM.classList.add('hidden'); });
    }

    // Desktop theme picker
    if (desktopThemeBtn && desktopThemePicker) {
      desktopThemeBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        desktopThemePicker.classList.toggle('hidden');
        if (themePicker) themePicker.classList.add('hidden');
      });
      document.addEventListener('click', function() {
        if (desktopThemePicker) desktopThemePicker.classList.add('hidden');
      });
      desktopThemePicker.addEventListener('click', function(e) { e.stopPropagation(); });
    }

    themeSwatches.forEach(function(swatch) {
      swatch.addEventListener('click', function() {
        applyTheme(swatch.getAttribute('data-theme-name'));
        if (themePicker) themePicker.classList.add('hidden');
        if (desktopThemePicker) desktopThemePicker.classList.add('hidden');
      });
    });

    mpThemeDots.forEach(function(dot) {
      dot.addEventListener('click', function() {
        applyTheme(dot.getAttribute('data-theme-name'));
      });
    });

    var savedTheme = localStorage.getItem('veloro-theme') || localStorage.getItem('theme-luxora') || 'violet';
    applyTheme(savedTheme);
  })();
</script>
