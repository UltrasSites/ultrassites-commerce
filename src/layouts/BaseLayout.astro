---
import { translations, languages } from '../i18n/translations';

interface Props {
  title: string;
  description: string;
  lang: string;
}

const { title, description, lang } = Astro.props;
const langKey = lang && lang in translations ? lang : 'fr';
const t = (translations as Record<string, Record<string, string>>)[langKey] || {};
const siteUrl = Astro.site || 'https://commerce.ultras-sites.com';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const pathWithoutLang = pathSegments.slice(1).join('/') || '';

const alternateLinks = Object.keys(languages).map((l) => ({
  lang: l,
  href: new URL(pathWithoutLang ? `/${l}/${pathWithoutLang}` : `/${l}/`, siteUrl).toString(),
}));
---

<!doctype html>
<html lang={langKey} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0d0a1e" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={langKey === 'fr' ? 'fr_FR' : langKey === 'en' ? 'en_US' : langKey === 'es' ? 'es_ES' : 'pt_PT'} />

    <!-- Alternate hreflang -->
    {alternateLinks.map((link) => (
      <link rel="alternate" hreflang={link.lang} href={link.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/fr/`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Outfit:wght@200;300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Theme restore (prevent flash) -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('veloro-theme') || localStorage.getItem('theme-luxora') || 'violet';
        var themes = {
          violet:   { bg: '#12073a', bg2: '#1c0e52', bg3: '#261566', accent: '#e8b84b', accentRgb: '232,184,75', accentDark: '#b88c28', text: '#f0ecff', text2: '#a89dd4', text3: '#7a6fa8', glassBg: 'rgba(18,7,58,0.6)' },
          midnight: { bg: '#040d1a', bg2: '#081828', bg3: '#0d2438', accent: '#7eb8f7', accentRgb: '126,184,247', accentDark: '#4a8fc7', text: '#e8f0fc', text2: '#7098c8', text3: '#4a6888', glassBg: 'rgba(4,13,26,0.62)' },
          ember:    { bg: '#1a0a05', bg2: '#261208', bg3: '#32180b', accent: '#e8784b', accentRgb: '232,120,75', accentDark: '#b84f28', text: '#fdf0eb', text2: '#c89078', text3: '#986050', glassBg: 'rgba(26,10,5,0.62)' },
          rose:     { bg: '#1a0812', bg2: '#26101c', bg3: '#331828', accent: '#e8a4c0', accentRgb: '232,164,192', accentDark: '#b87098', text: '#fdedf4', text2: '#c888a8', text3: '#986078', glassBg: 'rgba(26,8,18,0.62)' }
        };
        var t = themes[saved] || themes['violet'];
        var r = document.documentElement.style;
        r.setProperty('--bg', t.bg);
        r.setProperty('--bg2', t.bg2);
        r.setProperty('--bg3', t.bg3);
        r.setProperty('--accent', t.accent);
        r.setProperty('--accent-rgb', t.accentRgb);
        r.setProperty('--accent-dark', t.accentDark);
        r.setProperty('--text', t.text);
        r.setProperty('--text2', t.text2);
        r.setProperty('--text3', t.text3);
        r.setProperty('--glass-bg', t.glassBg);
        document.documentElement.setAttribute('data-theme', saved);
      })();
    </script>

    <slot name="head" />

    <style is:global>
      /* ══════════════════════════════════════
         LUXORA — BLACKBOX & LIQUID GLASS SYSTEM
         Inspired by Mast-renov design system
      ══════════════════════════════════════ */
      :root {
        --bg: #12073a; /* Violet profond luxe */
        --bg2: #1c0e52;
        --bg3: #261566;
        --accent: #e8b84b; /* Or chaud */
        --accent-rgb: 232, 184, 75;
        --accent-dark: #b88c28;
        --text: #f0ecff;
        --text2: #a89dd4;
        --text3: #7a6fa8;
        --glass-bg: rgba(18, 7, 58, 0.6);
        --glass-border: rgba(255, 255, 255, 0.08);
        --glass-shine: rgba(255, 255, 255, 0.15);
        --glass-blur: blur(24px);
        --radius-card: 20px;
        --radius-btn: 999px;
        --transition-spring: cubic-bezier(0.22, 1, 0.36, 1);
      }

      /* ══════════ RESET & BASE ══════════ */
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html { scroll-behavior: smooth; }

      body {
        font-family: 'Outfit', sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
        padding-bottom: calc(120px + env(safe-area-inset-bottom));
      }

      img { display: block; max-width: 100%; }
      a { text-decoration: none; color: inherit; }

      /* ══════════ BREATHING GRADIENT BACKGROUND ══════════ */
      @keyframes bgBreathe {
        0%   { opacity: 0.55; transform: scale(1) translate(0, 0); }
        50%  { opacity: 0.75; transform: scale(1.08) translate(-2%, 2%); }
        100% { opacity: 0.55; transform: scale(1) translate(0, 0); }
      }

      @keyframes bgBreathe2 {
        0%   { opacity: 0.35; transform: scale(1) translate(0, 0); }
        50%  { opacity: 0.5;  transform: scale(1.12) translate(3%, -2%); }
        100% { opacity: 0.35; transform: scale(1) translate(0, 0); }
      }

      body::after {
        content: '';
        position: fixed;
        inset: -20%;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(ellipse 60% 50% at 20% 30%, rgba(90, 50, 180, 0.28) 0%, transparent 70%),
          radial-gradient(ellipse 55% 45% at 80% 70%, rgba(140, 60, 200, 0.22) 0%, transparent 65%),
          radial-gradient(ellipse 40% 60% at 50% 50%, rgba(60, 30, 100, 0.18) 0%, transparent 80%);
        animation: bgBreathe 8s ease-in-out infinite alternate;
      }

      /* Noise texture overlay */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 9999;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
        pointer-events: none;
      }

      /* ══════════ LIQUID GLASS SYSTEM ══════════ */
      .liquid-glass {
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur) saturate(180%);
        -webkit-backdrop-filter: var(--glass-blur) saturate(180%);
        border: 1px solid var(--glass-border);
        box-shadow:
          inset 0 1px 1px var(--glass-shine),
          0 8px 32px rgba(0, 0, 0, 0.4);
      }

      /* ══════════ BUTTONS ══════════ */
      .liquid-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur) saturate(200%);
        -webkit-backdrop-filter: var(--glass-blur) saturate(200%);
        border: 1px solid var(--accent);
        border-radius: var(--radius-btn);
        color: var(--accent);
        font-family: 'Outfit', sans-serif;
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        padding: 1.1rem 2.5rem;
        cursor: pointer;
        box-shadow:
          inset 0 1px 1px var(--glass-shine),
          inset 0 -1px 1px rgba(0, 0, 0, 0.1),
          0 8px 24px rgba(var(--accent-rgb), 0.2);
        transition: all 0.4s var(--transition-spring);
      }

      .liquid-btn::before {
        content: '';
        position: absolute;
        top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(120deg, transparent, var(--glass-shine), transparent);
        transition: all 0.6s ease;
      }

      .liquid-btn:hover::before { left: 100%; }

      .liquid-btn:hover {
        transform: translateY(-3px);
        background: rgba(var(--accent-rgb), 0.15);
        box-shadow:
          inset 0 1px 1px var(--glass-shine),
          0 12px 32px rgba(var(--accent-rgb), 0.35);
      }

      .liquid-btn.primary {
        background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
        color: #000;
        border-color: var(--accent);
        font-weight: 700;
      }

      .liquid-btn.primary:hover {
        box-shadow:
          inset 0 1px 1px rgba(255,255,255,0.3),
          0 12px 40px rgba(var(--accent-rgb), 0.5);
        transform: translateY(-3px);
      }

      .liquid-btn.ghost {
        background: transparent;
        color: var(--text2);
        border-color: var(--glass-border);
        box-shadow: none;
      }

      .liquid-btn.ghost:hover {
        border-color: var(--text);
        color: var(--text);
        background: rgba(255,255,255,0.05);
        box-shadow: 0 8px 24px rgba(255,255,255,0.08);
      }

      /* ══════════ SECTION HEADERS ══════════ */
      .eyebrow {
        font-size: 0.6rem;
        letter-spacing: 0.6em;
        text-transform: uppercase;
        font-weight: 500;
        color: var(--accent);
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
      }

      .eyebrow::before,
      .eyebrow::after {
        content: '';
        width: 40px;
        height: 1px;
        background: var(--accent);
        flex-shrink: 0;
      }

      .section-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(2.5rem, 5vw, 4.5rem);
        line-height: 0.9;
        font-weight: 600;
        color: var(--text);
      }

      .section-subtitle {
        font-family: 'Cormorant Garamond', serif;
        font-style: italic;
        color: var(--text2);
        font-size: 1.1rem;
        font-weight: 300;
        line-height: 1.6;
        margin-top: 1rem;
        max-width: 540px;
      }

      /* ══════════ FADE UP ANIMATION ══════════ */
      .fade-up {
        opacity: 0;
        transform: translateY(40px);
        transition: all 1s var(--transition-spring);
      }

      .fade-up.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* ══════════ GOLD SHIMMER KEYFRAME ══════════ */
      @keyframes goldShimmer {
        0% { background-position: -200% center; }
        100% { background-position: 200% center; }
      }

      .gold-shimmer {
        background: linear-gradient(
          90deg,
          var(--text) 0%,
          var(--accent) 30%,
          #f5d98b 50%,
          var(--accent) 70%,
          var(--text) 100%
        );
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: goldShimmer 4s linear infinite;
      }

      /* ══════════ TOAST NOTIFICATION ══════════ */
      #luxora-toast {
        position: fixed;
        bottom: calc(140px + env(safe-area-inset-bottom));
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        z-index: 10000;
        background: var(--glass-bg);
        backdrop-filter: blur(24px);
        border: 1px solid var(--accent);
        border-radius: 999px;
        padding: 0.9rem 2rem;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--accent);
        opacity: 0;
        pointer-events: none;
        transition: all 0.4s var(--transition-spring);
        white-space: nowrap;
        box-shadow: 0 8px 32px rgba(var(--accent-rgb), 0.3), inset 0 1px 0 var(--glass-shine);
      }

      #luxora-toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      /* ══════════ SCROLLBAR ══════════ */
      ::-webkit-scrollbar { width: 4px; height: 4px; }
      ::-webkit-scrollbar-track { background: var(--bg2); }
      ::-webkit-scrollbar-thumb { background: var(--accent-dark); border-radius: 2px; }

      /* Desktop: hide dock */
      @media (min-width: 1024px) {
        #mobile-dock { display: none !important; }
        body { padding-bottom: 0; }
      }
    </style>
  </head>
  <body>
    <slot />

    <!-- Toast notification -->
    <div id="luxora-toast"></div>

    <!-- Cart system + tracking -->
    <script is:inline>
      // ═══════════════════════════════
      // CART SYSTEM (localStorage)
      // ═══════════════════════════════
      (function() {
        window.luxoraCart = JSON.parse(localStorage.getItem('luxora-cart') || '[]');

        window.addToCart = function(slug, name, price, toastText, qty) {
          qty = Math.max(1, parseInt(qty) || 1);
          var cart = window.luxoraCart;
          var existing = cart.find(function(i) { return i.slug === slug; });
          if (existing) {
            existing.qty += qty;
          } else {
            cart.push({ slug: slug, name: name, price: price, qty: qty });
          }
          saveCart(cart);
          showToast((toastText || name + ' ajouté au panier'));
        };

        window.updateCartQty = function(slug, delta) {
          var cart = window.luxoraCart;
          var item = cart.find(function(i) { return i.slug === slug; });
          if (item) {
            item.qty += delta;
            if (item.qty <= 0) {
              removeFromCart(slug);
            } else {
              saveCart(cart);
            }
          }
        };

        window.removeFromCart = function(slug) {
          window.luxoraCart = window.luxoraCart.filter(function(i) { return i.slug !== slug; });
          saveCart(window.luxoraCart);
        };

        function saveCart(cart) {
          localStorage.setItem('luxora-cart', JSON.stringify(cart));
          window.luxoraCart = cart;
          updateCartBadge();
          updateCartDrawer();
        }

        window.updateCartBadge = function() {
          var cart = window.luxoraCart;
          var total = cart.reduce(function(sum, i) { return sum + i.qty; }, 0);
          document.querySelectorAll('#cart-count').forEach(function(el) {
            el.textContent = total;
            el.style.display = total > 0 ? 'flex' : 'none';
          });
        };

        window.showToast = function(msg) {
          var toast = document.getElementById('luxora-toast');
          if (!toast) return;
          toast.textContent = msg;
          toast.classList.add('show');
          setTimeout(function() { toast.classList.remove('show'); }, 2800);
        };

        window.updateCartDrawer = function() {
          var listEl = document.getElementById('cart-items-list');
          var emptyEl = document.getElementById('cart-empty-state');
          var totalEl = document.getElementById('cart-total-amount');
          if (!listEl) return;

          var cart = window.luxoraCart;
          if (cart.length === 0) {
            listEl.innerHTML = '';
            if (emptyEl) emptyEl.style.display = 'flex';
            if (totalEl) totalEl.textContent = '0,00 €';
            return;
          }

          if (emptyEl) emptyEl.style.display = 'none';
          listEl.innerHTML = cart.map(function(item) {
            return '<div class="cart-item" data-slug="' + item.slug + '">' +
              '<div class="cart-item-info">' +
                '<span class="cart-item-name">' + item.name + '</span>' +
                '<div class="cart-qty-wrap">' +
                  '<button class="qty-btn" onclick="updateCartQty(\'' + item.slug + '\', -1)" aria-label="Moins">−</button>' +
                  '<span class="qty-val">' + item.qty + '</span>' +
                  '<button class="qty-btn" onclick="updateCartQty(\'' + item.slug + '\', 1)" aria-label="Plus">+</button>' +
                '</div>' +
              '</div>' +
              '<div class="cart-item-right">' +
                '<span class="cart-item-price">' + (item.price * item.qty).toFixed(2).replace('.', ',') + ' €</span>' +
                '<button class="cart-item-remove" onclick="removeFromCart(\'' + item.slug + '\')" aria-label="Supprimer">×</button>' +
              '</div>' +
            '</div>';
          }).join('');

          var total = cart.reduce(function(sum, i) { return sum + (i.price * i.qty); }, 0);
          if (totalEl) totalEl.textContent = total.toFixed(2).replace('.', ',') + ' €';
        };

        // Init on load
        document.addEventListener('DOMContentLoaded', function() {
          updateCartBadge();
          updateCartDrawer();
        });
        // Also init immediately in case DOM is ready
        updateCartBadge();
      })();
    </script>

    <!-- Ultras Tracking -->
    <script is:inline>
      (function() {
        if (location.pathname.indexOf('/ultras-ctrl') !== -1) return;
        var geo = {};
        var lang = document.documentElement.lang || 'fr';

        function send(type, target) {
          var d = {
            type: type,
            page: location.pathname,
            target: target || '',
            lang: lang,
            country: geo.country || 'XX',
            referrer: document.referrer || '',
            ua: navigator.userAgent.slice(0, 100),
            screen: screen.width + 'x' + screen.height,
            ts: Date.now(),
          };
          try { navigator.sendBeacon('/api/track', JSON.stringify(d)); } catch(e) {}
        }

        (function() {
          var cached = sessionStorage.getItem('geo_v1');
          if (cached) {
            try { geo = JSON.parse(cached); } catch(e) {}
            send('pageview');
          } else {
            try {
              fetch('/api/geo', { signal: typeof AbortSignal !== 'undefined' && AbortSignal.timeout ? AbortSignal.timeout(1500) : undefined })
                .then(function(r) { return r.ok ? r.json() : {}; })
                .then(function(data) {
                  geo = data || {};
                  try { sessionStorage.setItem('geo_v1', JSON.stringify(geo)); } catch(e) {}
                  send('pageview');
                })
                .catch(function() { send('pageview'); });
            } catch(e) { send('pageview'); }
          }
        })();

        document.addEventListener('click', function(e) {
          var el = e.target.closest('a[href], button');
          if (!el) return;
          var href = el.getAttribute('href') || '';
          var id = el.id || el.textContent.trim().slice(0, 50);
          if (href.indexOf('ultras-sites') !== -1 && href.indexOf('http') === 0) {
            send('demo', href);
          } else if (id.indexOf('cart') !== -1 || el.closest('[data-cart]')) {
            send('cart', id || href);
          } else if (id.indexOf('checkout') !== -1) {
            send('checkout', id);
          } else if (el.tagName === 'A' && href && href.indexOf('#') !== 0) {
            send('click', href.slice(0, 200));
          }
        }, true);
      })();
    </script>
  </body>
</html>
